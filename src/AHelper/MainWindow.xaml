<ui:FluentWindow x:Class="AHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AHelper"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:converters="clr-namespace:AHelper.Converters"
        mc:Ignorable="d"
        Title="A-Helper"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <converters:EnumEqualityMultiConverter x:Key="EnumEqualityMultiConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="A-Helper" />

        <StackPanel Grid.Row="1" Margin="16">

            <!-- Section header -->
            <TextBlock Text="{Binding SelectedMode, StringFormat='Mode: {0}'}"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,6" />

            <!-- The mode selector cards -->
            <ItemsControl ItemsSource="{Binding AvailableModes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RadioButton Style="{StaticResource ModeButtonStyle}"
                                     Content="{Binding}"
                                     Command="{Binding DataContext.SelectModeCommand,
                                               RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                     CommandParameter="{Binding}">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource EnumEqualityMultiConverter}" Mode="OneWay">
                                    <Binding Path="DataContext.SelectedMode" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                    <Binding />
                                </MultiBinding>
                            </RadioButton.IsChecked>
                        </RadioButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Grid>

</ui:FluentWindow>
